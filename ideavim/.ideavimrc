" ============================================================================
" Meow-style selection-first editing (mirrors the Emacs init.el meow QWERTY)
" ----------------------------------------------------------------------------
" The meow model (Kakoune-like): SELECT first, then ACT.
"   * selecting motions (w W e E b B f t x) enter Visual with a selection
"   * H J K L extend the selection; h j k l collapse it and move
"   * action keys work on the selection, or on the char under the cursor:
"       s = kill/cut   d = delete (black hole)   c = change
"       y = copy       p = paste                 r = replace with clipboard
"   * there are therefore NO d/c/y operators: no dd, cw, diw, yy.
"     to act on a whole line: x (select line) then s / d / c / y.
" This follows init.el's meow keys, not vanilla Vim: q quits, m joins, g
" cancels the selection, v / n / N drive search, , / . grab the inner / bounds
" of a thing, ' repeats, and u / U are the IDE's undo / redo (shared with the
" Emacs C-/ stack). Emacs chords (C-a/e/k/y/w/d, C-x..., C-s, C-space, M-x)
" still work everywhere — they are routed to the IDE up top.

" Word selection like meow: a BARE e/b STEPS to the next/prev word, but after
" w (which 'arms' grow mode) e/b GROW the selection. g:wsel is the arm flag.
" It is WRITTEN by the normal-mode w/e/b maps with :let (a real command that
" persists) and only READ in these <expr> funcs — reads survive IdeaVim's
" <expr> sandbox, writes don't, so the flag is never set from inside here.
" When growing, line/col "v" gives the anchor so we flip the active end
" (prepend o) only when needed, so w-then-b grows left and repeats.
let g:wsel = 0
function! VWordE()
  if g:wsel
    if line(".") < line("v") || (line(".") == line("v") && col(".") < col("v"))
      return "oe"
    endif
    return "e"
  endif
  return "\<Esc>eviw"
endfunction
function! VWordEW()
  if g:wsel
    if line(".") < line("v") || (line(".") == line("v") && col(".") < col("v"))
      return "oE"
    endif
    return "E"
  endif
  return "\<Esc>EviW"
endfunction
function! VWordB()
  if g:wsel
    if line(".") > line("v") || (line(".") == line("v") && col(".") > col("v"))
      return "ob"
    endif
    return "b"
  endif
  return "\<Esc>bviwo"
endfunction
function! VWordBW()
  if g:wsel
    if line(".") > line("v") || (line(".") == line("v") && col(".") > col("v"))
      return "oB"
    endif
    return "B"
  endif
  return "\<Esc>BviWo"
endfunction
" x grows the line selection outward: down if the active end is at/below the
" anchor, up if it is above. So after ; (swap ends) x grows the OTHER way.
function! GrowLine()
  if line(".") < line("v")
    return "k"
  endif
  return "j"
endfunction

" --- lowercase h j k l: move, dropping the selection ---
xnoremap h <Esc>h
xnoremap j <Esc>j
xnoremap k <Esc>k
xnoremap l <Esc>l

" --- uppercase H J K L: start / extend a selection ---
nnoremap H vh
nnoremap J vj
nnoremap K vk
nnoremap L vl
xnoremap H h
xnoremap J j
xnoremap K k
xnoremap L l

" --- 1-9 / 0 / - : meow-expand-N (extend the selection by N units) ---
" A digit extends the live selection by N; the unit tracks the selection type —
" line-wise (from x) grows by lines, char-wise (from w / e / b / f / t) grows by
" words. 0 = 10, and - extends back one unit. mode() picks the unit; like the
" VWord* funcs above these are <expr> and only READ state (mode/line/col),
" never write it. Normal-mode counts (3w) are untouched; SPC 1-9 count there too.
function! MeowExpand(n)
  if mode() ==# "V"
    return a:n . "j"
  endif
  return a:n . "e"
endfunction
function! MeowExpandBack()
  if mode() ==# "V"
    return "k"
  endif
  return "b"
endfunction
xnoremap <expr> 1 MeowExpand(1)
xnoremap <expr> 2 MeowExpand(2)
xnoremap <expr> 3 MeowExpand(3)
xnoremap <expr> 4 MeowExpand(4)
xnoremap <expr> 5 MeowExpand(5)
xnoremap <expr> 6 MeowExpand(6)
xnoremap <expr> 7 MeowExpand(7)
xnoremap <expr> 8 MeowExpand(8)
xnoremap <expr> 9 MeowExpand(9)
xnoremap <expr> 0 MeowExpand(10)
xnoremap <expr> - MeowExpandBack()

" --- selecting motions: enter Visual with a selection ---
" w / W: mark the word / WORD and ARM grow mode (:let persists the flag)
nnoremap w :<C-u>let g:wsel=1<CR>viw
xnoremap w <Esc>viw
nnoremap W :<C-u>let g:wsel=1<CR>viW
xnoremap W <Esc>viW
" e / E: a BARE e STEPS to the next word; after w it GROWS the selection right
nnoremap e :<C-u>let g:wsel=0<CR>eviw
xnoremap <expr> e VWordE()
nnoremap E :<C-u>let g:wsel=0<CR>EviW
xnoremap <expr> E VWordEW()
" b / B: a BARE b STEPS to the prev word; after w it GROWS the selection left
nnoremap b :<C-u>let g:wsel=0<CR>bviwo
xnoremap <expr> b VWordB()
nnoremap B :<C-u>let g:wsel=0<CR>BviWo
xnoremap <expr> B VWordBW()
" find / till a character (selects up to it)
nnoremap f vf
nnoremap t vt
nnoremap F vF
nnoremap T vT
" whole line; tap x to grow the selection down a line (; then x grows up)
nnoremap x V
xnoremap <expr> x GrowLine()
nnoremap X G
xnoremap X G
" expand / shrink the selection by syntax (meow-block / meow-to-block)
nnoremap o <action>(EditorSelectWord)
xnoremap o <action>(EditorSelectWord)
nnoremap O <action>(EditorUnSelectWord)
xnoremap O <action>(EditorUnSelectWord)
" reverse the selection (swap its active end)
xnoremap ; o
" inner / bounds of a thing: , or . then a text-object char, e.g. ,( or .(
nnoremap , vi
nnoremap . va
" ' repeats the last change (meow keeps . for bounds, above)
nnoremap ' .
" cancel the selection (meow-cancel-selection)
nnoremap g <Esc>
xnoremap g <Esc>
" join lines (meow-join)
nnoremap m J
xnoremap m J
" quit the editor (meow-quit)
nnoremap q :q<cr>
" visit: open the IDE search; n / N then walk the matches (meow-visit)
nnoremap v <action>(Find)

" --- insert around the selection / open lines ---
" I / A open a line above / below (meow-open-above / meow-open-below)
nnoremap I O
nnoremap A o
" in Visual, i / a drop in at the start / end of the selection
xnoremap i <Esc>`<i
xnoremap a <Esc>`>a
xnoremap I <Esc>O
xnoremap A <Esc>o

" --- act on the selection (or the char under the cursor) ---
" kill / cut to the clipboard
nnoremap s x
xnoremap s d
" delete without touching the clipboard (black hole register)
nnoremap d "_x
nnoremap D "_X
xnoremap d "_d
xnoremap D "_d
" change
nnoremap c cl
" copy
nnoremap y yl
" replace the selection with the clipboard, leaving the clipboard intact
xnoremap r "_dP
" redo on U; u stays IdeaVim's native undo. Both already run on the IDE's
" UndoManager (the same stack as Emacs C-/), so DON'T use <action>($Undo/$Redo)
" here — those fire with no editor in their data context and silently no-op.
nnoremap U <C-r>