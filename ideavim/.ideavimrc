" Share system clipboard with IdeaVim
set clipboard+=unnamedplus

" Use IDE-aware join behavior
set ideajoin

" Case-insensitive search by default
set ignorecase
set smartcase

" Show absolute line numbers
set number

" Enable various UX plugins
set visualbell        " Use visual bell instead of audible

" Which-Key style popup for <leader> mappings
set which-key
set notimeout
" Which-Key group descriptions — the leader mirrors the Emacs/Meow keypad
let g:WhichKeyDesc_leader_x  = "<leader>x C-x · file / buffer / window"
let g:WhichKeyDesc_leader_xp = "<leader>xp C-x p · project"
let g:WhichKeyDesc_leader_c  = "<leader>c C-c · commands (= M-m)"
let g:WhichKeyDesc_leader_cj = "<leader>cj C-c j · avy jump"
let g:WhichKeyDesc_leader_m  = "<leader>m M- · meta"
let g:WhichKeyDesc_leader_ms = "<leader>ms M-s · search"
let g:WhichKeyDesc_leader_w  = "<leader>w window map (Emacs C-c w)"

" Control-key handler routing: whether keys go to IDE or Vim
" a - all modes, n - normal, i - insert, v - visual
" I use the Emacs keymap in IntelliJ, so hand every Emacs editing chord to the
" IDE in all modes. Only C-[ stays with Vim, as the way back to normal mode.
sethandler <c-a> a:ide
sethandler <c-b> a:ide
sethandler <c-c> a:ide
sethandler <c-d> a:ide
sethandler <c-e> a:ide
sethandler <c-f> a:ide
sethandler <c-g> a:ide
sethandler <c-h> a:ide
sethandler <c-i> a:ide
sethandler <c-j> a:ide
sethandler <c-k> a:ide
sethandler <c-l> a:ide
sethandler <c-m> a:ide
sethandler <c-n> a:ide
sethandler <c-o> a:ide
sethandler <c-p> a:ide
sethandler <c-r> a:ide
sethandler <c-s> a:ide
sethandler <c-u> a:ide
sethandler <c-v> a:ide
sethandler <c-w> a:ide
sethandler <c-x> a:ide
sethandler <c-y> a:ide
sethandler <c-/> a:ide
sethandler <c-space> a:ide
sethandler <c-[> a:vim

" Space is the leader key
let mapleader=" "

" M-m behaves like <leader> (must be map, not noremap). In init.el M-m is
" translated to C-c (key-translation-map), and the leader's SPC c mirrors C-c,
" so Alt-m here is the same "command prefix" entry point.
map <A-m> <Space>

" meow-search: n / N repeat the IDE search (Emacs C-s starts it; v opens Find)
nnoremap n <action>(FindNext)
nnoremap N <action>(FindPrevious)
" In a selection (after w / W), n / N jump to the next / prev occurrence of
" the word under the cursor and reselect it — meow-search after meow-mark-word.
" * / # re-derive the word each time and wrap, so no stale-pattern E486.
xnoremap n <Esc>*viw
xnoremap N <Esc>#viw

" Resize editor splits with - = _ +
map - <action>(StretchSplitToBottom)
map = <action>(StretchSplitToTop)
map _ <action>(StretchSplitToLeft)
map + <action>(StretchSplitToRight)

" EasyMotion / avy — enabled here so the leader maps below can reach its <Plug>
" targets. init.el meow parity: S = avy-goto-char-timer (2-char jump),
" Q = avy-goto-line (lowercase s is meow-kill / cut — see the Meow section).
let g:EasyMotion_do_mapping=0
set easymotion
nmap S <Plug>(easymotion-bd-f2)
nmap Q <Plug>(easymotion-bd-jk)

" VCS / diff / error navigation (diff-hl C-x v ] / [, flymake-style next/prev)
map ]c <action>(VcsShowNextChangeMarker)
map [c <action>(VcsShowPrevChangeMarker)
map ]d <action>(NextDiff)
map [d <action>(PreviousDiff)
map ]e <action>(GotoNextError)
map [e <action>(GotoPreviousError)

" ============================================================================
" Leader = Emacs / Meow keypad
" ----------------------------------------------------------------------------
" The leader (<Space>, also Alt-m) mirrors how Meow's keypad reaches the Emacs
" keymap in init.el: press the same keys after <Space> that you'd press after
" SPC in Emacs, and you get the IntelliJ action matching that Emacs command.
"   SPC x  = the C-x prefix (files / buffers / windows)
"   SPC c  = the C-c prefix (= M-m; the personal commands in init.el)
"   SPC m  = the M- (Meta) prefix
"   SPC w  = the window map (Emacs C-c w, "SPC w" in Meow)
" So SPC x f = C-x C-f = find-file, SPC c f = C-c f = find-file, SPC m x = M-x.
" Whatever has no dedicated key is one M-x away: SPC m x = Find Action.

" --- direct leader keys (meow-leader-define-key) ---
" SPC b  consult-buffer   (SPC s = consult-line now lives on SPC s s — see
" the IntelliJ <leader>s group below)
map <leader>b   <action>(RecentFiles)

" --- SPC 1-9 = meow-digit-argument : a count for the next command ---
" Vim already counts when you type a number directly; these mirror Meow, where
" the leader carries the count because the normal-mode digits do meow-expand-N
" (below). Normal mode only, e.g. SPC 3 then j = 3 lines down.
nnoremap <leader>1 1
nnoremap <leader>2 2
nnoremap <leader>3 3
nnoremap <leader>4 4
nnoremap <leader>5 5
nnoremap <leader>6 6
nnoremap <leader>7 7
nnoremap <leader>8 8
nnoremap <leader>9 9

" --- SPC x = C-x : files / buffers / windows ---
" f find-file        s save         b buffers      k kill-buffer
" d dired(project)   g magit(VCS)   o other-window u undo history
" v vc-prefix        c quit         0/1/2/3 splits
map <leader>xf  <action>(GotoFile)
map <leader>xs  <action>(SaveAll)
map <leader>xb  <action>(RecentFiles)
map <leader>xk  <action>(CloseContent)
map <leader>xd  <action>(ActivateProjectToolWindow)
map <leader>xg  <action>(ActivateVersionControlToolWindow)
map <leader>xo  <action>(NextSplitter)
map <leader>xu  <action>(LocalHistory.ShowHistory)
map <leader>xv  <action>(Vcs.Operations.Popup)
map <leader>xc  <action>(CloseProject)
map <leader>x0  <action>(Unsplit)
map <leader>x1  <action>(UnsplitAll)
map <leader>x2  <action>(SplitHorizontally)
map <leader>x3  <action>(SplitVertically)

" --- SPC x p = C-x p : project.el ---
" f find-file   b buffer   g grep   r replace   c compile
map <leader>xpf <action>(GotoFile)
map <leader>xpb <action>(RecentFiles)
map <leader>xpg <action>(FindInPath)
map <leader>xpr <action>(ReplaceInPath)
map <leader>xpc <action>(CompileProject)

" --- SPC c = C-c : commands (= M-m) ---
" f find-file  s save  k kill-buffer  b buffers  r ripgrep  e expand
" a agenda(TODO)  c capture(scratch)  l store-link(copy ref)  g git file ops
" v / V edit / reload this config
map <leader>cf  <action>(GotoFile)
map <leader>cs  <action>(SaveAll)
map <leader>ck  <action>(CloseContent)
map <leader>cb  <action>(RecentFiles)
map <leader>cr  <action>(FindInPath)
map <leader>ce  <action>(EditorSelectWord)
map <leader>ca  <action>(ActivateTODOToolWindow)
map <leader>cc  <action>(NewScratchFile)
map <leader>cl  <action>(CopyReference)
map <leader>cg  <action>(Vcs.Operations.Popup)
map <leader>cv  :edit ~/.ideavimrc<cr>
map <leader>cV  :source ~/.ideavimrc<cr>

" --- SPC c j = C-c j : avy jumps (-> EasyMotion) ---
" w avy-goto-char-2   c avy-goto-char-timer   l avy-goto-line
map <leader>cjw <Plug>(easymotion-bd-f2)
map <leader>cjc <Plug>(easymotion-bd-f2)
map <leader>cjl <Plug>(easymotion-bd-jk)

" --- SPC m = M- : meta ---
" x execute-command  o avy  r expand  R contract  y yank-pop
" . dwim (go-to-def)  g avy-goto-line
map <leader>mx  <action>(GotoAction)
map <leader>mo  <Plug>(easymotion-bd-f2)
map <leader>mr  <action>(EditorSelectWord)
map <leader>mR  <action>(EditorUnSelectWord)
map <leader>my  <action>(PasteMultiple)
map <leader>m.  <action>(GotoDeclaration)
map <leader>mg  <Plug>(easymotion-bd-jk)

" --- SPC m s = M-s : consult search family ---
" r ripgrep  l line  s line  L line-multi  o outline
map <leader>msr <action>(FindInPath)
map <leader>msl <action>(Find)
map <leader>mss <action>(Find)
map <leader>msL <action>(FindInPath)
map <leader>mso <action>(FileStructurePopup)

" --- SPC w = the window map (Emacs C-c w) ---
" v / s  split right / below     d delete      D / m delete-others (maximize)
" w other-window   W swap        h j k l focus move
" i / = zoom in     o / - zoom out     u / 0 reset zoom
map <leader>wv  <action>(SplitVertically)
map <leader>ws  <action>(SplitHorizontally)
map <leader>wd  <action>(Unsplit)
map <leader>wD  <action>(UnsplitAll)
map <leader>wm  <action>(UnsplitAll)
map <leader>ww  <action>(NextSplitter)
map <leader>wW  <action>(MoveEditorToOppositeTabGroup)
map <leader>wh  <c-w>h
map <leader>wj  <c-w>j
map <leader>wk  <c-w>k
map <leader>wl  <c-w>l
map <leader>wi  <action>(EditorIncreaseFontSize)
map <leader>w=  <action>(EditorIncreaseFontSize)
map <leader>wo  <action>(EditorDecreaseFontSize)
map <leader>w-  <action>(EditorDecreaseFontSize)
map <leader>wu  <action>(EditorResetFontSize)
map <leader>w0  <action>(EditorResetFontSize)

" --- non-prefixed extras ---
" SPC <CR> ~ embark-act (Alt-Enter)   SPC SPC alternate file   SPC / comment
map <leader><cr>     <action>(ShowIntentionActions)
map <leader><leader> <c-^>
map <leader>/        <action>(CommentByLineComment)

